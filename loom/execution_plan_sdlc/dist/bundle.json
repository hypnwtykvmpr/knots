      "queue": "ready_for_orchestration",
      "action": "orchestration"
    }
  ],
  "phases": [
    {
      "id": "authoring_phase",
      "produce_step": "design",
      "gate_step": "review"
    },
    {
      "id": "orchestration_phase",
      "produce_step": "orchestration",
      "gate_step": null
    }
  ],
  "profiles": [
    {
      "id": "autopilot",
      "display_name": "Autopilot",
      "description": "Agent-owned design and review flow for execution plan authoring",
      "phases": [
        "authoring_phase",
        "orchestration_phase"
      ],
      "outputs": {
        "design": {
          "artifact_type": "note",
          "access_hint": null
        },
        "review": {
          "artifact_type": "approval",
          "access_hint": null
        },
        "orchestration": {
          "artifact_type": "note",
          "access_hint": null
        }
      },
      "executors": {
        "design": "agent",
        "review": "agent",
        "orchestration": "agent"
      }
    },
    {
      "id": "semiauto",
      "display_name": "Semi-automatic",
      "description": "Human-reviewed execution plan authoring flow",
      "phases": [
        "authoring_phase",
        "orchestration_phase"
      ],
      "outputs": {
        "design": {
          "artifact_type": "note",
          "access_hint": null
        },
        "review": {
          "artifact_type": "approval",
          "access_hint": null
        },
        "orchestration": {
          "artifact_type": "note",
          "access_hint": null
        }
      },
      "executors": {
        "design": "agent",
        "review": "human",
        "orchestration": "agent"
      }
    }
  ],
  "prompts": [
    {
      "name": "design",
      "accept": [
        "Objective and scope are reflected in the plan design",
        "Waves and dependencies are coherent",
        "The plan records clear next actions for downstream execution"
      ],
      "params": [],
      "outcomes": [
        {
          "name": "design_complete",
          "target": "ready_for_review",
          "is_success": true
        },
        {
          "name": "insufficient_context",
          "target": "ready_for_design",
          "is_success": false
        },
        {
          "name": "blocked_by_dependency",
          "target": "blocked",
          "is_success": false
        }
      ],
      "body": "# Design\n\nAuthor the execution plan artifact for this knot.\n\n## Step Boundary\n\n- This session is authorized only for `design`.\n- Complete exactly one design action, then stop.\n- Allowed resting states after this session: `ready_for_review`,\n  `ready_for_design`, or `blocked`.\n- Record the design in the plan artifact output before advancing.\n\n## Actions\n\n1. Review the knot goal, description, and existing context.\n2. Draft a coherent execution plan structure with waves, dependencies, and\n   handoff-ready details.\n3. Ensure the authored plan is suitable for a later review pass.\n4. Advance to `ready_for_review` when the design is ready.",
      "body_params": []
    },
    {
      "name": "review",
      "accept": [
        "The execution plan design is complete and internally consistent",
        "The proposed waves and dependencies are reviewable and actionable",
        "The artifact is ready to serve as the source plan for execution"
      ],
      "params": [],
      "outcomes": [
        {
          "name": "approved",
          "target": "ready_for_orchestration",
          "is_success": true
        },
        {
          "name": "changes_requested",
          "target": "ready_for_design",
          "is_success": false
        },
        {
          "name": "blocked_by_dependency",
          "target": "blocked",
          "is_success": false
        }
      ],
      "body": "# Review\n\nReview the authored execution plan before it advances to orchestration.\n\n## Step Boundary\n\n- This session is authorized only for `review`.\n- Complete exactly one review action, then stop.\n- Allowed resting states after this session: `ready_for_orchestration`,\n  `ready_for_design`, or `blocked`.\n- Review work is metadata-only and should not modify repository code.\n\n## Actions\n\n1. Inspect the authored plan artifact and its supporting knot context.\n2. Confirm the design is complete, coherent, and actionable.\n3. Approve the plan to advance to orchestration, or send it back for revision.",
      "body_params": []
    },
    {
      "name": "orchestration",
      "accept": [
        "The execution plan has been driven forward according to its next queued work",
        "The orchestration outcome is recorded in a handoff-ready note",
        "Downstream progress or blockers are clear from the orchestration output"
      ],
      "params": [],
      "outcomes": [
        {
          "name": "orchestration_complete",
          "target": "shipped",
          "is_success": true
        },
        {
          "name": "blocked_by_dependency",
          "target": "blocked",
          "is_success": false
        }
      ],
      "body": "# Orchestration\n\nDrive the approved execution plan forward after review has passed.\n\n## Step Boundary\n\n- This session is authorized only for `orchestration`.\n- Complete exactly one orchestration action, then stop.\n- Allowed resting states after this session: `shipped` or `blocked`.\n- Record the orchestration outcome in the note output before advancing.\n\n## Actions\n\n1. Review the approved execution plan and the current status of its waves and\n   steps.\n2. Advance the next ready work in the plan according to the documented\n   sequencing constraints.\n3. Record the orchestration outcome, including any blockers or handoffs needed\n   for downstream follow-through.\n4. Advance to `shipped` when orchestration is complete.",
      "body_params": []
    }
  ],
  "transitions": {
    "wildcard_targets": [
      "abandoned",
      "deferred"
    ],
    "queue_to_action": [
      {
        "id": "design",
        "queue": "ready_for_design",
        "action": "design"
      },
      {
        "id": "review",
        "queue": "ready_for_review",
        "action": "review"
      },
      {
        "id": "orchestration",
        "queue": "ready_for_orchestration",
        "action": "orchestration"
      }
    ],
    "outcome_tables": [
      {
        "action": "design",
        "prompt": "design",
        "success": {
          "design_complete": "ready_for_review"
        },
        "failure": {
          "insufficient_context": "ready_for_design",
          "blocked_by_dependency": "blocked"
        }
      },
      {
        "action": "review",
        "prompt": "review",
        "success": {
          "approved": "ready_for_orchestration"
        },
        "failure": {
          "changes_requested": "ready_for_design",
          "blocked_by_dependency": "blocked"
        }
      },
      {
        "action": "orchestration",
        "prompt": "orchestration",
        "success": {
          "orchestration_complete": "shipped"
        },
        "failure": {
          "blocked_by_dependency": "blocked"
        }
      }
    ]
  }
}