{
  "name": "knots",
  "version": "0.16.4",
  "private": true,
  "description": "Release tooling for the Knots CLI",
  "license": "MIT",
  "scripts": {
    "changeset": "changeset",
    "version-packages": "changeset version && node ./scripts/release/sync-cargo-version.mjs",
    "check-cargo-version": "node ./scripts/release/sync-cargo-version.mjs --check",
    "check-changesets": "node ./scripts/release/check-changesets.mjs",
    "test-release": "node --test ./scripts/release/*.test.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.0"
  }
}
